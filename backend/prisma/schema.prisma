generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Tenants ──
model Tenant {
  id                 String   @id @default(uuid())
  name               String
  slug               String?  @unique
  ownerId            String?
  subscriptionPlan   String   @default("free")
  subscriptionStatus String   @default("active")
  subscriptionExpiry DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users              User[]
  clients            Client[]
  agents             Agent[]
  vendors            Vendor[]
  leads              Lead[]
  tasks              Task[]
  bookings           Booking[]
  invoices           Invoice[]
  payments           Payment[]
  quotations         Quotation[]
  accounts           Account[]
  transactions       Transaction[]
  expenses           Expense[]
  hajjPackages       HajjPackage[]
  hajjGroups         HajjGroup[]
  hajjPilgrims       HajjPilgrim[]
  vendorBills        VendorBill[]
  subscriptions      Subscription[]
  paymentRequests    PaymentRequest[]
  domains            TenantDomain[]
}

// ── Tenant Domains ──
model TenantDomain {
  id                 String   @id @default(uuid())
  tenantId           String
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  domain             String   @unique
  wwwRedirect        String   @default("www-to-root") // "www-to-root" | "root-to-www"
  status             String   @default("pending")     // "active" | "pending" | "error"
  sslStatus          String   @default("none")        // "active" | "pending" | "none"
  verificationStatus String   @default("unverified")  // "unverified" | "verifying" | "verified"
  verificationToken  String
  isPrimary          Boolean  @default(false)
  lastDnsCheck       DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ── Users ──
model User {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  password         String
  role             String    @default("sales_agent")
  resetToken       String?
  resetTokenExpiry DateTime?
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
}

// ── Clients ──
model Client {
  id              String   @id @default(uuid())
  name            String
  phone           String   @default("")
  email           String   @default("")
  alternatePhone  String?
  address         String?
  dateOfBirth     String?
  passportNumber  String?
  passportExpiry  String?
  nidNumber       String?
  nationality     String?
  emergencyContact String?
  emergencyPhone  String?
  notes           String?
  tags            String[] @default([])
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bookings        Booking[]
  invoices        Invoice[]
  leads           Lead[]
  quotations      Quotation[]
  documents       ClientDocument[]
}

model ClientDocument {
  id         String   @id @default(uuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name       String
  type       String
  url        String
  uploadedAt DateTime @default(now())
}

// ── Agents ──
model Agent {
  id        String   @id @default(uuid())
  name      String
  phone     String   @default("")
  email     String   @default("")
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  bookings  Booking[]
}

// ── Vendors ──
model Vendor {
  id            String   @id @default(uuid())
  name          String
  phone         String   @default("")
  email         String   @default("")
  category      String   @default("other")
  contactPerson String?
  address       String?
  serviceAreas  String?
  website       String?
  bankDetails   String?
  notes         String?
  status        String   @default("active")
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bills         VendorBill[]
  vendorNotes   VendorNote[]
  expenses      Expense[]
}

model VendorBill {
  id          String   @id @default(uuid())
  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  bookingId   String?
  segmentId   String?
  description String
  totalAmount Float    @default(0)
  paidAmount  Float    @default(0)
  dueAmount   Float    @default(0)
  status      String   @default("unpaid")
  dueDate     String?
  invoiceRef  String?
  notes       String?
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  payments    VendorBillPayment[]
}

model VendorBillPayment {
  id        String   @id @default(uuid())
  billId    String
  bill      VendorBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  amount    Float
  method    String
  reference String?
  date      String
  notes     String?
  paidBy    String?
  createdAt DateTime @default(now())
}

model VendorNote {
  id        String   @id @default(uuid())
  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  type      String   @default("note")
  content   String
  createdBy String?
  createdAt DateTime @default(now())
}

// ── Leads ──
model Lead {
  id             String   @id @default(uuid())
  name           String
  phone          String   @default("")
  email          String   @default("")
  status         String   @default("new")
  source         String?
  destination    String?
  travelDateFrom String?
  travelDateTo   String?
  travelerCount  Int?
  budget         Float?
  assignedTo     String?
  nextFollowUp   String?
  notes          String?
  tags           String[] @default([])
  clientId       String?
  client         Client?  @relation(fields: [clientId], references: [id])
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  activities     LeadActivity[]
  quotations     Quotation[]
}

model LeadActivity {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String
  content   String
  oldStatus String?
  newStatus String?
  createdBy String?
  createdAt DateTime @default(now())
}

// ── Tasks ──
model Task {
  id          String   @id @default(uuid())
  title       String
  description String   @default("")
  status      String   @default("todo")
  priority    String   @default("medium")
  dueDate     String?
  assignedTo  String?
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

// ── Bookings ──
model Booking {
  id              String   @id @default(uuid())
  type            String   @default("package")
  title           String?
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id])
  agentId         String?
  agent           Agent?   @relation(fields: [agentId], references: [id])
  quotationId     String?
  destination     String?
  travelDateFrom  String?
  travelDateTo    String?
  travelerCount   Int?
  amount          Float    @default(0)
  cost            Float    @default(0)
  profit          Float    @default(0)
  paidAmount      Float    @default(0)
  dueAmount       Float    @default(0)
  paymentStatus   String   @default("unpaid")
  status          String   @default("pending")
  assignedTo      String?
  supplierName    String?
  supplierRef     String?
  internalNotes   String?
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  segments        BookingSegment[]
  travelers       BookingTraveler[]
  checklist       BookingChecklistItem[]
  timeline        BookingTimelineEvent[]
  documents       BookingDocument[]
  invoices        Invoice[]
}

model BookingSegment {
  id           String  @id @default(uuid())
  bookingId    String
  booking      Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  type         String
  description  String
  supplier     String?
  supplierRef  String?
  startDate    String?
  endDate      String?
  details      String?
  cost         Float   @default(0)
  sellingPrice Float   @default(0)
  status       String  @default("pending")
}

model BookingTraveler {
  id             String  @id @default(uuid())
  bookingId      String
  booking        Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  name           String
  passportNumber String?
  passportExpiry String?
  nationality    String?
  dateOfBirth    String?
  phone          String?
  email          String?
  notes          String?
}

model BookingChecklistItem {
  id        String   @id @default(uuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  label     String
  done      Boolean  @default(false)
  doneAt    DateTime?
  doneBy    String?
}

model BookingTimelineEvent {
  id        String   @id @default(uuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  type      String
  content   String
  oldStatus String?
  newStatus String?
  createdBy String?
  createdAt DateTime @default(now())
}

model BookingDocument {
  id         String   @id @default(uuid())
  bookingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  name       String
  type       String
  url        String
  uploadedAt DateTime @default(now())
  uploadedBy String?
}

// ── Invoices ──
model Invoice {
  id              String   @id @default(uuid())
  invoiceNumber   String?
  bookingId       String
  booking         Booking  @relation(fields: [bookingId], references: [id])
  clientId        String?
  client          Client?  @relation(fields: [clientId], references: [id])
  clientName      String?
  bookingTitle    String?
  totalAmount     Float    @default(0)
  paidAmount      Float    @default(0)
  dueAmount       Float    @default(0)
  refundedAmount  Float    @default(0)
  status          String   @default("unpaid")
  dueDate         String?
  issuedDate      String?
  notes           String?
  cancelReason    String?
  createdBy       String?
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payments        Payment[]
  refunds         InvoiceRefund[]
  auditTrail      InvoiceAuditEvent[]
}

model Payment {
  id             String   @id @default(uuid())
  invoiceId      String
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  bookingId      String
  amount         Float
  method         String
  transactionRef String?
  proofUrl       String?
  date           String
  notes          String?
  receivedBy     String?
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
}

model InvoiceRefund {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount      Float
  reason      String
  method      String?
  processedBy String?
  createdAt   DateTime @default(now())
}

model InvoiceAuditEvent {
  id        String   @id @default(uuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  type      String
  content   String
  oldStatus String?
  newStatus String?
  amount    Float?
  createdBy String?
  createdAt DateTime @default(now())
}

// ── Quotations ──
model Quotation {
  id                 String   @id @default(uuid())
  title              String
  clientId           String?
  client             Client?  @relation(fields: [clientId], references: [id])
  leadId             String?
  lead               Lead?    @relation(fields: [leadId], references: [id])
  destination        String
  travelDateFrom     String?
  travelDateTo       String?
  travelerCount      Int      @default(1)
  status             String   @default("draft")
  version            Int      @default(1)
  items              Json     @default("[]")
  itinerary          Json     @default("[]")
  totalCost          Float    @default(0)
  totalSelling       Float    @default(0)
  totalProfit        Float    @default(0)
  discountAmount     Float    @default(0)
  taxAmount          Float    @default(0)
  grandTotal         Float    @default(0)
  validUntil         String?
  notes              String?
  termsAndConditions String?
  createdBy          String?
  tenantId           String
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  versions           QuotationVersion[]
}

model QuotationVersion {
  id            String    @id @default(uuid())
  quotationId   String
  quotation     Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  versionNumber Int
  snapshot      String
  changeNote    String?
  changedBy     String?
  createdAt     DateTime  @default(now())
}

// ── Accounts ──
model Account {
  id            String   @id @default(uuid())
  name          String
  type          String
  balance       Float    @default(0)
  accountNumber String?
  bankName      String?
  notes         String?
  status        String   @default("active")
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactions  Transaction[]
  expenses      Expense[]
}

model Transaction {
  id            String   @id @default(uuid())
  accountId     String?
  account       Account? @relation(fields: [accountId], references: [id])
  type          String
  category      String
  description   String
  amount        Float
  referenceId   String?
  referenceType String?
  clientId      String?
  bookingId     String?
  vendorId      String?
  invoiceId     String?
  paymentMethod String?
  status        String   @default("completed")
  date          String
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy     String?
  createdAt     DateTime @default(now())
}

model Expense {
  id            String   @id @default(uuid())
  category      String
  description   String
  amount        Float
  date          String
  paymentMethod String
  reference     String?
  notes         String?
  attachmentUrl String?
  vendorId      String?
  vendor        Vendor?  @relation(fields: [vendorId], references: [id])
  accountId     String?
  account       Account? @relation(fields: [accountId], references: [id])
  approvedBy    String?
  status        String   @default("pending")
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ── Hajj/Umrah ──
model HajjPackage {
  id               String   @id @default(uuid())
  name             String
  type             String
  status           String   @default("upcoming")
  duration         String   @default("")
  makkahNights     Int      @default(0)
  madinahNights    Int      @default(0)
  makkahHotel      String?
  madinahHotel     String?
  hotelClass       String   @default("economy")
  flightInfo       String?
  visaIncluded     Boolean  @default(false)
  transportIncluded Boolean @default(false)
  mealsIncluded    Boolean  @default(false)
  ziyaratIncluded  Boolean  @default(false)
  packagePrice     Float    @default(0)
  costPrice        Float    @default(0)
  profit           Float    @default(0)
  capacity         Int      @default(0)
  enrolled         Int      @default(0)
  departureDate    String?
  returnDate       String?
  highlights       String?
  notes            String?
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  groups           HajjGroup[]
  pilgrims         HajjPilgrim[]
}

model HajjGroup {
  id               String   @id @default(uuid())
  packageId        String
  package          HajjPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  name             String
  leader           String
  leaderPhone      String?
  departureDate    String
  returnDate       String
  flightDetails    String?
  transportSchedule String?
  notes            String?
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())

  pilgrims         HajjPilgrim[]
}

model HajjPilgrim {
  id               String   @id @default(uuid())
  packageId        String
  package          HajjPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  groupId          String
  group            HajjGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  clientId         String?
  name             String
  phone            String   @default("")
  email            String?
  dateOfBirth      String?
  gender           String?
  passportNumber   String   @default("")
  passportExpiry   String?
  nidNumber        String?
  nationality      String?
  mahramName       String?
  mahramRelation   String?
  mahramPilgrimId  String?
  roomType         String?
  roomNumber       String?
  roomPartners     String?
  status           String   @default("registered")
  visaStatus       String   @default("not_started")
  departureStatus  String   @default("not_departed")
  totalAmount      Float    @default(0)
  paidAmount       Float    @default(0)
  dueAmount        Float    @default(0)
  paymentStatus    String   @default("unpaid")
  emergencyContact String?
  emergencyPhone   String?
  medicalNotes     String?
  notes            String?
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  payments         HajjPilgrimPayment[]
}

model HajjPilgrimPayment {
  id              String   @id @default(uuid())
  pilgrimId       String
  pilgrim         HajjPilgrim @relation(fields: [pilgrimId], references: [id], onDelete: Cascade)
  amount          Float
  method          String
  reference       String?
  date            String
  note            String?
  installmentLabel String?
  receivedBy      String?
  createdAt       DateTime @default(now())
}

// ── Subscriptions & Payment Requests (Super Admin) ──
model Subscription {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan      String
  startDate String
  endDate   String
  status    String   @default("active")
  createdAt DateTime @default(now())
}

model PaymentRequest {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan            String
  amount          Float
  method          String   @default("manual")
  trxId           String
  proofUrl        String?
  status          String   @default("pending")
  reviewerComment String?
  processedAt     DateTime?
  createdAt       DateTime @default(now())
}

// ── Audit Logs ──
model AuditLog {
  id          String   @id @default(uuid())
  actorId     String
  actorName   String
  actorEmail  String
  actorRole   String
  tenantId    String?
  tenantName  String?
  module      String
  action      String
  targetType  String?
  targetId    String?
  targetLabel String?
  oldValue    String?
  newValue    String?
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())
}
