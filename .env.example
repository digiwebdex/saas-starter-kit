# ══════════════════════════════════════════════════
# Frontend Environment Variables (.env.production)
# Copy this file to .env.production on your VPS
# ══════════════════════════════════════════════════

# Backend API URL (your Express server)
VITE_API_URL=https://api.yourdomain.com/api

# App domain for multi-tenant subdomain detection
# e.g. "yourdomain.com" → tenants load as acme.yourdomain.com
VITE_APP_DOMAIN=yourdomain.com
